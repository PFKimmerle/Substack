# Required - get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Vision model (optional - defaults shown)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Plant lookup APIs (optional)
# PERENUAL_KEY=your_perenual_key_here
# TREFLE_TOKEN=your_trefle_token_here

# Server config (optional - defaults shown)
# PORT=3000
# CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
# GROQ_BASE=https://api.groq.com/openai
# GROQ_DAILY_LIMIT=1000

# Redis cache (optional - uses in-memory if not set)
# REDIS_URL=redis://localhost:6379
